{
  "manifest_version": 3,
  "name": "JSR AI Autonomous Agent",
  "version": "64.0",
  "description": "Ultimate autonomous browser agent for JSR AI. Multi-step, multi-tab, conditional, looping, self-driving plans.",
  "permissions": ["tabs", "scripting", "storage", "alarms", "webNavigation", "cookies", "activeTab", "downloads"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JSR AI Agent"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["executor.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.lovable.app/*",
        "*://*.lovable.dev/*",
        "http://localhost/*",
        "http://localhost:*/*"
      ],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
