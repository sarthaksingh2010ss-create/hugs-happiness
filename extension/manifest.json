{
  "manifest_version": 3,
  "name": "JSR AI Autonomous Agent",
  "version": "61.0",
  "description": "JSR AI's hands on the browser. Executes action plans on any website.",
  "permissions": ["tabs", "scripting", "storage", "alarms", "webNavigation", "cookies", "activeTab"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "JSR AI Agent"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["<all_urls>"],
    "js": ["executor.js"],
    "run_at": "document_idle"
  }]
}
