{
  "manifest_version": 3,
  "name": "JSR AI Autonomous Agent",
  "version": "65.0",
  "description": "Ultimate autonomous browser agent for JSR AI. Multi-step, multi-tab, looping, conditional, self-driving — maxed-out browser control.",
  "permissions": ["tabs", "scripting", "storage", "alarms", "webNavigation", "cookies", "activeTab", "downloads", "notifications", "contextMenus", "clipboardWrite", "clipboardRead"],
  "host_permissions": ["<all_urls>"],
  "action": { "default_popup": "popup.html", "default_title": "JSR AI Agent" },
  "background": { "service_worker": "background.js" },
  "commands": {
    "_execute_action": { "suggested_key": { "default": "Ctrl+Shift+J" } }
  },
  "content_scripts": [
    { "matches": ["<all_urls>"], "js": ["executor.js"], "run_at": "document_idle", "all_frames": true },
    { "matches": ["*://*.lovable.app/*", "*://*.lovable.dev/*", "http://localhost/*", "http://localhost:*/*"], "js": ["bridge.js"], "run_at": "document_start" }
  ]
}
